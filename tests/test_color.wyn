var RED = 31
var GREEN = 32
var BLUE = 34
var BOLD = 1
var RESET = 0

test "red" {
    assert_eq(RED, 31)
}

test "green" {
    assert_eq(GREEN, 32)
}

test "blue" {
    assert_eq(BLUE, 34)
}

test "bold" {
    assert_eq(BOLD, 1)
}

test "reset" {
    assert_eq(RESET, 0)
}

test "colors print" {
    Terminal.print_color("ok\n", GREEN)
    assert(true)
}
